          <mxGeometry height="28" width="60" x="930" y="630" as="geometry" />
        </mxCell>
        <mxCell id="40" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;spacex_launches.db&lt;/b&gt;&#xa;SQLite&#xa;launches table&#xa;18 rows" vertex="1">
          <mxGeometry height="120" width="200" x="460" y="830" as="geometry" />
        </mxCell>
        <mxCell id="41" parent="1" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff4e0;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;vehicle_specs.json&lt;/b&gt;&#xa;file on disk&#xa;keyed by vehicle name&#xa;4 rockets" vertex="1">
          <mxGeometry height="120" width="200" x="880" y="830" as="geometry" />
        </mxCell>
        <mxCell id="50" parent="1" style="swimlane;startSize=30;whiteSpace=wrap;html=1;fillColor=#fff4e0;strokeColor=#d79b00;fontSize=12;fontStyle=1;fontColor=#7a4f00;align=center;" value="Trace of the example question" vertex="1">
          <mxGeometry height="850" width="540" x="1620" y="100" as="geometry" />
        </mxCell>
        <mxCell id="51" parent="50" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=6;" value="&lt;b&gt;step 1 · thought&lt;/b&gt;&#xa;Need to find which rocket flies crewed&#xa;missions. Call query_launches." vertex="1">
          <mxGeometry height="60" width="500" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="52" parent="50" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=top;spacing=6;fontStyle=1;" value="&lt;b&gt;step 1 · action&lt;/b&gt;&#xa;query_launches(&quot;SELECT DISTINCT vehicle&#xa;FROM launches WHERE payload_type = &#39;Crew&#39;&quot;)" vertex="1">
          <mxGeometry height="60" width="500" x="20" y="120" as="geometry" />
        </mxCell>
        <mxCell id="53" parent="50" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=6;" value="&lt;b&gt;step 1 · observation&lt;/b&gt;&#xa;[{&quot;vehicle&quot;: &quot;Falcon 9&quot;}]" vertex="1">
          <mxGeometry height="50" width="500" x="20" y="190" as="geometry" />
        </mxCell>
        <mxCell id="54" parent="50" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=6;" value="&lt;b&gt;step 2 · thought&lt;/b&gt;&#xa;Falcon 9. Now look up its thrust." vertex="1">
          <mxGeometry height="50" width="500" x="20" y="260" as="geometry" />
        </mxCell>
        <mxCell id="55" parent="50" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=top;spacing=6;fontStyle=1;" value="&lt;b&gt;step 2 · action&lt;/b&gt;&#xa;vehicle_specs(&quot;Falcon 9&quot;)" vertex="1">
          <mxGeometry height="50" width="500" x="20" y="320" as="geometry" />
        </mxCell>
        <mxCell id="56" parent="50" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=6;" value="&lt;b&gt;step 2 · observation&lt;/b&gt;&#xa;{thrust_kn: 7607, height_m: 70, mass_kg: 549054,&#xa; payload_to_leo_kg: 22800, reusable: true, ...}" vertex="1">
          <mxGeometry height="60" width="500" x="20" y="380" as="geometry" />
        </mxCell>
        <mxCell id="57" parent="50" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=6;" value="&lt;b&gt;step 3 · thought&lt;/b&gt;&#xa;Have rocket name and thrust. Compose answer." vertex="1">
          <mxGeometry height="50" width="500" x="20" y="450" as="geometry" />
        </mxCell>
        <mxCell id="58" parent="50" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=6;fontStyle=1;" value="&lt;b&gt;Final Answer&lt;/b&gt;&#xa;The rocket used for crewed missions is the&#xa;Falcon 9, which has a thrust of 7,607 kN." vertex="1">
          <mxGeometry height="60" width="500" x="20" y="510" as="geometry" />
        </mxCell>
        <mxCell id="59" parent="50" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#7a4f00;" value="3 LLM calls. 2 tool calls. The LLM picked the order. We did not write any if-else." vertex="1">
          <mxGeometry height="40" width="500" x="20" y="600" as="geometry" />
        </mxCell>
        <mxCell id="60" parent="50" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;In a pipeline:&lt;/b&gt; we would have to write the if-else by hand. With every new question type we would add another branch. With every new data source, every branch would need updating. The agent absorbs that complexity into the LLM&#39;s decision." vertex="1">
          <mxGeometry height="120" width="500" x="20" y="660" as="geometry" />
        </mxCell>
