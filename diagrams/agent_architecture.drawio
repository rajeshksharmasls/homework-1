        <mxCell id="22" parent="10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" value="&lt;b&gt;no tool_calls -&gt; emit Final Answer (final string)&lt;/b&gt;" vertex="1">
          <mxGeometry height="50" width="780" x="20" y="350" as="geometry" />
