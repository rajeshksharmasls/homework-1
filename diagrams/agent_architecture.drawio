  <diagram name="Multi-tool ReAct Agent" id="0">
    <mxGraphModel dx="2473" dy="1255" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1200" math="0" shadow="0">
