        </mxCell>
        <mxCell id="30" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4e7e3;strokeColor=#3d8b85;fontSize=11;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;@tool query_launches&lt;/b&gt;&#xa;sql: str  →  rows (JSON)&#xa;&#xa;Read-only SELECT on launches table.&#xa;Same FORBIDDEN list and LIMIT injection&#xa;as the pipeline&#39;s validator." vertex="1">
          <mxGeometry height="120" width="360" x="380" y="640" as="geometry" />
        </mxCell>
        <mxCell id="31" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4e7e3;strokeColor=#3d8b85;fontSize=11;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;@tool vehicle_specs&lt;/b&gt;&#xa;vehicle: str  →  spec sheet (JSON)&#xa;&#xa;Lookup in vehicle_specs.json.&#xa;Returns thrust, height, mass, payload_to_leo,&#xa;reusable, active, first_flight, notes." vertex="1">
          <mxGeometry height="120" width="360" x="800" y="640" as="geometry" />
        </mxCell>
