        <mxCell id="2" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1f3b73;" value="Multi-tool ReAct Agent (SpaceX)" vertex="1">
          <mxGeometry height="40" width="2120" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="3" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#666666;" value="One agent class. Two tools. The LLM decides which to call, in what order, and when to stop." vertex="1">
          <mxGeometry height="22" width="2120" x="40" y="60" as="geometry" />
        </mxCell>
        <mxCell id="4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" value="&lt;b&gt;User&lt;/b&gt;" vertex="1">
          <mxGeometry height="80" width="140" x="40" y="120" as="geometry" />
        </mxCell>
        <mxCell id="5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;Example question&lt;/b&gt;&#xa;&quot;What is the thrust of the rocket&#xa;we use for crewed missions?&quot;&#xa;&#xa;The pipeline cannot answer this. The SQL&#xa;database has the rocket name. The JSON has&#xa;the thrust. Need both, in order." vertex="1">
          <mxGeometry height="140" width="480" x="210" y="100" as="geometry" />
        </mxCell>
        <mxCell id="10" parent="1" style="swimlane;startSize=30;whiteSpace=wrap;html=1;fillColor=#1f3b73;fontColor=#ffffff;fontStyle=1;strokeColor=#1f3b73;fontSize=14;" value="Agent (one Python function with a loop)" vertex="1">
          <mxGeometry height="450" width="820" x="720" y="100" as="geometry" />
        </mxCell>
        <mxCell id="11" parent="10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="ChatOpenAI&#xa;(.bind_tools)" vertex="1">
          <mxGeometry height="50" width="180" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="12" parent="10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="Tool registry&#xa;(2 tools)" vertex="1">
          <mxGeometry height="50" width="180" x="220" y="50" as="geometry" />
        </mxCell>
        <mxCell id="13" parent="10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="messages list&#xa;(grows each step)" vertex="1">
          <mxGeometry height="50" width="180" x="420" y="50" as="geometry" />
        </mxCell>
        <mxCell id="14" parent="10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="max_iters = 8&#xa;(safety valve)" vertex="1">
          <mxGeometry height="50" width="180" x="620" y="50" as="geometry" />
        </mxCell>
        <mxCell id="15" parent="10" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#ffffff;" value="ReAct loop  (run until LLM emits no tool_calls)" vertex="1">
          <mxGeometry height="20" width="780" x="20" y="120" as="geometry" />
